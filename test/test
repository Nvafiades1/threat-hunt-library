index=vm sourcetype IN ("vmware:esxlog:envoy-access","vmware:esxlog:perfcharts-localhost_access")
| rex field=downstream_remote_addr "^(?<src_ip>[^:]+)"
| where NOT (cidrmatch("10.10.10.175/32", src_ip) OR cidrmatch("10.10.21.0/24", src_ip))
| rex field=_raw "\s(?<http_method>GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS)\s+(?<full_uri>\S+)"
| rex field=full_uri "(?<uri_path>[^?]+)"
| rex field=full_uri "[^?]+\?(?<query_params>.+)"
| eval has_script_ext=if(match(uri_path, "(?i)\.(jsp|jspx|php|phtml|asp|aspx|ashx|war|pl|py|sh|cgi|cfm)$"), "true", "false")
| rex field=query_params max_match=0 "(?<param_name>[^=&]+)=(?<param_value>[^&]+)"
| mvexpand param_value
| eval decoded_value=trim(urldecode(param_value))
| where len(decoded_value) >= 20
| where match(decoded_value, "^[A-Za-z0-9+/_\-]{20,}={0,2}$")
| eval decrypted=base64decode(decoded_value)
| where isnotnull(decrypted) AND len(decrypted) > 0
| eval ascii_only=replace(decrypted, "[^\x20-\x7e\t\n\r]", "")
| eval printability=if(len(decrypted)>0, round(len(ascii_only)/len(decrypted), 2), 0)
| where printability >= 0.85
| eval shell_keywords=if(match(decrypted, "(?i)(/bin/(sh|bash)|cmd\.exe|powershell|whoami|uname|/etc/(passwd|shadow)|wget |curl |nc |2>&1|certutil|bitsadmin|net\s+(user|group|localgroup)|ifconfig|ipconfig|id;|cat\s+/|interact\.sh|oast\.|burpcollab|\.\./)"), "true", "false")
| eval message="WEBSHELL ALERT: " . http_method . " " . uri_path . " | param=" . param_name . " | printability=" . printability . " | shell_kw=" . shell_keywords . " | cleartext: " . decrypted
| table _time, host, src_ip, http_method, uri_path, has_script_ext, param_name, param_value, decrypted, printability, shell_keywords, message
